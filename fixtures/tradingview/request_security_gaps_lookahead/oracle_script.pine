//@version=6
indicator("pinelib tv oracle indicator v1", overlay=false, max_labels_count=500)
sec_w_gaps_on_la_off = request.security(syminfo.tickerid, "W", close, gaps=barmerge.gaps_on, lookahead=barmerge.lookahead_off)
sec_w_gaps_off_la_off = request.security(syminfo.tickerid, "W", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
sec_w_gaps_on_la_on = request.security(syminfo.tickerid, "W", close, gaps=barmerge.gaps_on, lookahead=barmerge.lookahead_on)
sec_w_gaps_off_la_on = request.security(syminfo.tickerid, "W", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
ltf_close = request.security_lower_tf(syminfo.tickerid, "60", close)
ltf_high = request.security_lower_tf(syminfo.tickerid, "60", high)
ltf_low = request.security_lower_tf(syminfo.tickerid, "60", low)
[macd_line, macd_signal, macd_hist] = ta.macd(close, 12, 26, 9)
plot(time, "bar_time")
plot(time_close, "bar_time_close")
plot(time("W"), "time_W")
plot(time_close("W"), "time_close_W")
plot(sec_w_gaps_on_la_off, "sec_w_gaps_on_la_off")
plot(sec_w_gaps_off_la_off, "sec_w_gaps_off_la_off")
plot(sec_w_gaps_on_la_on, "sec_w_gaps_on_la_on")
plot(sec_w_gaps_off_la_on, "sec_w_gaps_off_la_on")
plot(array.size(ltf_close), "ltf60_close_count")
plot(array.size(ltf_close) > 0 ? array.get(ltf_close, 0) : na, "ltf60_close_first")
plot(array.size(ltf_close) > 0 ? array.get(ltf_close, array.size(ltf_close)-1) : na, "ltf60_close_last")
plot(array.size(ltf_high) > 0 ? array.max(ltf_high) : na, "ltf60_high_max")
plot(array.size(ltf_low) > 0 ? array.min(ltf_low) : na, "ltf60_low_min")
plot(ta.sma(close, 5), "sma5")
plot(ta.ema(close, 5), "ema5")
plot(ta.rma(close, 5), "rma5")
plot(ta.rsi(close, 14), "rsi14")
plot(ta.atr(14), "atr14")
plot(macd_line, "macd_line")
plot(macd_signal, "macd_signal")
plot(macd_hist, "macd_hist")
plot(ta.stoch(close, high, low, 14), "stoch14")
