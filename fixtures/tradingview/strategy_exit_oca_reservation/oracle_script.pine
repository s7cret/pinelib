//@version=6
strategy("pinelib_oracle_strategy_exit_oca_reservation_v1", overlay=false, pyramiding=1, initial_capital=100000, calc_on_order_fills=true, process_orders_on_close=false)
int start = last_bar_index - 60
if bar_index == start
    strategy.entry("OCA_L", strategy.long, qty=20)
if bar_index == start + 1
    strategy.exit("LIM_RESERVE_19", from_entry="OCA_L", qty=19, limit=close - 1000)
    strategy.exit("STOP_REDUCED_20", from_entry="OCA_L", qty=20, stop=close + 1000)
if bar_index == start + 3 and strategy.position_size > 0
    strategy.close("OCA_L", comment="FORCE_REMAINDER")
float t_no = na
float ent_bar = na
float ex_bar = na
float ent_px = na
float ex_px = na
float sz = na
float prof = na
if strategy.closedtrades > nz(strategy.closedtrades[1])
    int n = strategy.closedtrades - 1
    t_no := n
    ent_bar := strategy.closedtrades.entry_bar_index(n)
    ex_bar := strategy.closedtrades.exit_bar_index(n)
    ent_px := strategy.closedtrades.entry_price(n)
    ex_px := strategy.closedtrades.exit_price(n)
    sz := strategy.closedtrades.size(n)
    prof := strategy.closedtrades.profit(n)
plot(time, "tv_bar_time")
plot(open, "tv_open")
plot(high, "tv_high")
plot(low, "tv_low")
plot(close, "tv_close")
plot(strategy.closedtrades, "tv_closedtrades_count")
plot(strategy.position_size, "tv_position_size")
plot(t_no, "tv_trade_no")
plot(ent_bar, "tv_entry_bar_index")
plot(ex_bar, "tv_exit_bar_index")
plot(ent_px, "tv_entry_price")
plot(ex_px, "tv_exit_price")
plot(sz, "tv_size")
plot(prof, "tv_profit")
